ENVIRONMENT=development
DEBUG=true

# Upstage Solar API 키
# 발급: https://console.upstage.ai/
UPSTAGE_API_KEY=your_upstage_api_key
LLM_MODEL=solar-pro3

# Supabase 설정
SUPABASE_URL=your_key
SUPABASE_KEY=your_key

# 멀티 환경 Docker Compose 옵션
STAGING_PORT=8001
STAGING_DEBUG=false
PRODUCTION_PORT=8000
PRODUCTION_IMAGE=ghcr.io/ai-pre/lumi-agent2/lumi-agent:latest
